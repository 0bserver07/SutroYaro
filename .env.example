# Telegram API credentials (for reading via bin/tg-sync)
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram Bot credentials (for writing via bin/tg-post)
# Create a bot via @BotFather, get chat ID via: bin/tg-post --get-chat-id
TELEGRAM_BOT_TOKEN=
SUTRO_GROUP_CHAT_ID=

# Safety: posting is disabled by default. Set to 1 to enable.
# TELEGRAM_POST_ENABLED=1
